<!DOCTYPE html>
<html lang="<%= locals.lang || 'en' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= locals.t ? t.heroTitle : 'Weather Guides' %> | Holiday Extras</title>
  <meta name="description" content="Live weather guides for popular holiday destinations. Check today's conditions and plan your perfect trip with Holiday Extras." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" href="https://dmy0b9oeprz0f.cloudfront.net/holidayextras.co.uk/favicon/96/recent.jpg" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
</head>
<body>

  <%- include('partials/header', { user }) %>

  <!-- Hero -->
  <section class="index-hero">
    <div class="container">
      <p class="hero-strapline"><%= locals.t ? t.heroStrapline : 'Less hassle. More holiday.' %></p>
      <h1><%= locals.t ? t.heroTitle : 'Weather Guides' %></h1>
      <p class="hero-sub"><%= locals.t ? t.heroSub : 'Live weather for popular holiday destinations — plan your trip with confidence.' %></p>

      <!-- Search bar -->
      <div class="search-wrapper" role="search">
        <div class="search-bar" id="search-bar">
          <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="2"/>
            <line x1="13" y1="13" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <input
            type="search"
            id="search-input"
            class="search-input"
            placeholder="<%= locals.t ? t.searchPlaceholder : 'Search for a destination...' %>"
            autocomplete="off"
            aria-label="Search for a destination"
            aria-controls="search-results"
            aria-autocomplete="list"
          />
        </div>
        <ul class="search-results" id="search-results" role="listbox" aria-label="Search results" hidden></ul>
      </div>
    </div>
  </section>

  <!-- Language Switcher -->
  <% if (locals.alternates && alternates.length > 1) { %>
  <div class="lang-bar">
    <div class="container">
      <div class="lang-switcher">
        <% var langMeta = { en: { flag: '🇬🇧', label: 'EN' }, de: { flag: '🇩🇪', label: 'DE' }, fr: { flag: '🇫🇷', label: 'FR' }, es: { flag: '🇪🇸', label: 'ES' }, it: { flag: '🇮🇹', label: 'IT' } }; %>
        <span class="lang-switcher__label"><%= locals.t ? t.switchLanguage : 'Switch language:' %></span>
        <% alternates.forEach(function(a) { var lm = langMeta[a.lang] || { flag: '', label: a.lang.toUpperCase() }; %>
          <a href="<%= a.href %>" class="lang-pill<%= (a.lang === (locals.lang || 'en')) ? ' lang-pill--active' : '' %>" hreflang="<%= a.lang %>"><%= lm.flag %> <%= lm.label %></a>
        <% }); %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Local Weather + Trip Search -->
  <section class="local-weather-section">
    <div class="local-weather-section__header">
      <div class="container local-weather-section__header-inner">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z" fill="currentColor"/></svg>
        <h2><%= locals.t ? t.planYourHoliday : 'Plan Your Next Holiday' %></h2>
      </div>
    </div>
    <div class="container local-weather-row">

      <!-- Weather card: only shown when geolocation is granted -->
      <div class="local-weather-card" id="local-weather-card" hidden>
        <div class="local-weather-card__header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" fill="currentColor"/></svg>
          <h2><%= locals.t ? t.weatherNearYou : 'Weather Near You' %></h2>
        </div>
        <div class="local-weather-loading" id="local-weather-loading"></div>
        <div class="local-weather-content" id="local-weather-content" hidden></div>
      </div>

      <!-- Trip search: always visible -->
      <form class="trip-search-widget" method="GET" action="https://www.holidayextras.com/mfe/search/trip/new" target="_blank">
        <div class="trip-search__header">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 16v-2l-8-5V3.5a1.5 1.5 0 0 0-3 0V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z" fill="currentColor"/></svg>
          <h2><%= locals.t ? t.newTripHeader : 'New Trip' %></h2>
        </div>
        <p class="trip-search__sub"><%= locals.t ? t.freeCancellation : 'Free cancellation · Best price guaranteed' %></p>

        <div class="trip-search__field">
          <label class="trip-search__label" for="ts_airport"><%= locals.t ? t.flyingFrom : 'Flying from' %></label>
          <select id="ts_airport" name="flying_from" class="trip-search__select">
            <option value="LGW">Gatwick LGW</option>
            <option value="LHR">Heathrow LHR</option>
            <option value="STN">Stansted STN</option>
            <option value="LTN">Luton LTN</option>
            <option value="SEN">Southend SEN</option>
            <option value="ABZ">Aberdeen Dyce ABZ</option>
            <option value="BFS">Belfast BFS</option>
            <option value="BHD">Belfast City BHD</option>
            <option value="BHX">Birmingham BHX</option>
            <option value="BOH">Bournemouth BOH</option>
            <option value="BRS">Bristol BRS</option>
            <option value="CWL">Cardiff CWL</option>
            <option value="DSA">Doncaster Sheffield DSA</option>
            <option value="DUB">Dublin DUB</option>
            <option value="EMA">East Midlands EMA</option>
            <option value="EDI">Edinburgh EDI</option>
            <option value="EXT">Exeter EXT</option>
            <option value="GLA">Glasgow GLA</option>
            <option value="PIK">Glasgow Prestwick PIK</option>
            <option value="HUY">Humberside HUY</option>
            <option value="INV">Inverness INV</option>
            <option value="LBA">Leeds Bradford LBA</option>
            <option value="LPL">Liverpool John Lennon LPL</option>
            <option value="LCY">London City LCY</option>
            <option value="MAN">Manchester MAN</option>
            <option value="NCL">Newcastle NCL</option>
            <option value="NWI">Norwich NWI</option>
            <option value="SNN">Shannon SNN</option>
            <option value="SOU">Southampton SOU</option>
            <option value="MME">Teesside MME</option>
          </select>
        </div>

        <div class="trip-search__dates">
          <div class="trip-search__field">
            <label class="trip-search__label" for="ts_depart"><%= locals.t ? t.outboundFlight : 'Outbound flight' %></label>
            <input type="date" id="ts_depart" name="departure_date" class="trip-search__date" required />
          </div>
          <div class="trip-search__field">
            <label class="trip-search__label" for="ts_return"><%= locals.t ? t.returnFlight : 'Return flight' %></label>
            <input type="date" id="ts_return" name="return_date" class="trip-search__date" required />
          </div>
        </div>

        <button type="submit" class="trip-search__btn"><%= locals.t ? t.searchBtn : 'Search' %></button>
      </form>

    </div>
    </div>
  </section>

  <!-- Main Widgets -->
  <section class="home-main-section">
    <div class="container home-main-grid">

      <!-- Holiday Weather Now Widget -->
      <div class="hwn-widget">

        <div class="hwn-header">
          <h2 class="hwn-title"><%= locals.t ? t.holidayWeatherNow : 'Holiday Weather Now' %></h2>
        </div>

        <div class="hwn-controls">
          <div class="hwn-meta">
            <span class="hwn-sort-label" id="hwn-sort-label"><%= locals.t ? t.sortedByPopularity : 'Sorted by popularity:' %></span>
            <span class="hwn-updated">Updated at <%= updatedAt %> GMT</span>
          </div>
          <div class="hwn-sort-btns" role="group" aria-label="Sort destinations">
            <button class="hwn-sort-btn hwn-sort-btn--active" data-sort="popularity" title="Sort by popularity">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <polyline points="2,14 7,8 11,11 18,4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="14,4 18,4 18,8" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="hwn-sort-btn" data-sort="temperature" title="Sort by warmest">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="2"/>
                <line x1="10" y1="1" x2="10" y2="3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="10" y1="16.5" x2="10" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="1" y1="10" x2="3.5" y2="10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="16.5" y1="10" x2="19" y2="10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="3.22" y1="3.22" x2="5" y2="5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="15" y1="15" x2="16.78" y2="16.78" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="3.22" y1="16.78" x2="5" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="15" y1="5" x2="16.78" y2="3.22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
            <button class="hwn-sort-btn" data-sort="az" title="Sort A–Z">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <text x="1" y="10" font-family="sans-serif" font-size="7" font-weight="700" fill="currentColor">A</text>
                <text x="1" y="18" font-family="sans-serif" font-size="7" font-weight="700" fill="currentColor">Z</text>
                <line x1="14" y1="3" x2="14" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <polyline points="10,13 14,17 18,13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>

        <ul class="hwn-list" id="hwn-list">
          <% displayCountries.forEach((c, idx) => {
            const w = weatherMap[c.slug];
          %>
          <li class="hwn-item"
              data-temp="<%= w ? w.temperature : -99 %>"
              data-name="<%= c.displayName %>"
              data-popularity="<%= c.popularity %>">
            <a href="<%= weatherLinkPrefix %><%= c.localSlug %>" class="hwn-item-link">
              <div class="hwn-item-bar"></div>
              <span class="hwn-flag" aria-hidden="true"><%= c.flag %></span>
              <span class="hwn-country"><%= c.displayName %></span>
              <span class="hwn-condition-emoji" aria-hidden="true"><%= w ? w.emoji : '🌡️' %></span>
              <span class="hwn-temp"><%= w ? w.temperature + '°C' : '—' %></span>
              <svg class="hwn-arrow" width="10" height="16" viewBox="0 0 10 16" fill="none" aria-hidden="true">
                <polyline points="2,2 8,8 2,14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
          <% }) %>
        </ul>


      </div>

      <!-- Blog Widget -->
      <div class="blog-widget">
        <div class="blog-widget__header">
          <h2 class="blog-widget__title"><%= locals.t ? t.holidayWeatherBlog : 'Holiday Weather Blog' %></h2>
          <a href="/blog" class="blog-widget__see-more"><%= locals.t ? t.seeMore : 'See more →' %></a>
        </div>
        <% blogPosts.slice(0, 3).forEach((post, i) => { %>
        <article class="blog-row<%= i > 0 ? ' blog-row--border' : '' %>">
          <div class="blog-row__content">
            <p class="blog-row__category">
              <span class="blog-cat-badge"><%= post.categoryEmoji %></span>
              <%= post.category %>
            </p>
            <h3 class="blog-row__title"><a href="/blog/<%= post.slug %>"><%= post.title %></a></h3>
            <p class="blog-row__excerpt"><%= post.excerpt %></p>
            <a href="/blog/<%= post.slug %>" class="blog-read-more">Read More</a>
          </div>
          <% if (post.image) { %>
          <a href="/blog/<%= post.slug %>" class="blog-row__img-link" tabindex="-1" aria-hidden="true">
            <img src="<%- post.image %>" alt="" class="blog-row__img" loading="lazy" />
          </a>
          <% } %>
        </article>
        <% }) %>
      </div>

    </div>
  </section>

  <script>
    (function () {
      const list = document.getElementById('hwn-list');
      const sortLabel = document.getElementById('hwn-sort-label');
      const sortBtns = document.querySelectorAll('.hwn-sort-btn');

      const sortLabels = {
        popularity: '<%= locals.t ? t.sortedByPopularity : "Sorted by popularity:" %>',
        temperature: '<%= locals.t ? t.sortedByWarmest : "Sorted by warmest:" %>',
        az: '<%= locals.t ? t.sortedAZ : "Sorted A–Z:" %>'
      };

      function sortList(mode) {
        const items = Array.from(list.querySelectorAll('.hwn-item'));
        items.sort((a, b) => {
          if (mode === 'temperature') return +b.dataset.temp - +a.dataset.temp;
          if (mode === 'az') return a.dataset.name.localeCompare(b.dataset.name);
          return +a.dataset.popularity - +b.dataset.popularity;
        });
        items.forEach(el => list.appendChild(el));
      }

      sortBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          sortBtns.forEach(b => b.classList.remove('hwn-sort-btn--active'));
          btn.classList.add('hwn-sort-btn--active');
          sortLabel.textContent = sortLabels[btn.dataset.sort];
          sortList(btn.dataset.sort);
        });
      });
    })();
  </script>

  <script>
    (function () {
      const input = document.getElementById('search-input');
      const results = document.getElementById('search-results');
      const bar = document.getElementById('search-bar');
      let timer;

      input.addEventListener('input', () => {
        clearTimeout(timer);
        const q = input.value.trim();
        if (!q) { hideResults(); return; }
        timer = setTimeout(() => fetchResults(q), 150);
      });

      async function fetchResults(q) {
        const res = await fetch('/search?q=' + encodeURIComponent(q));
        const data = await res.json();
        if (!data.length) { hideResults(); return; }
        results.innerHTML = data.map(r =>
          `<li class="search-result-item" role="option">
            <a href="/weather/${r.slug}" class="search-result-link">
              <span class="search-result-flag">${r.flag}</span>
              <span class="search-result-name">${r.name}</span>
              <span class="search-result-capital">${r.capital}</span>
            </a>
          </li>`
        ).join('');
        results.hidden = false;
        bar.classList.add('search-bar--open');
      }

      function hideResults() {
        results.hidden = true;
        results.innerHTML = '';
        bar.classList.remove('search-bar--open');
      }

      document.addEventListener('click', e => {
        if (!e.target.closest('.search-wrapper')) hideResults();
      });

      input.addEventListener('keydown', e => {
        if (e.key === 'Escape') { hideResults(); input.blur(); }
      });
    })();
  </script>

  <script>
    // Set default dates for trip search
    (function () {
      const today = new Date();
      const ret = new Date(today); ret.setDate(ret.getDate() + 7);
      const fmt = d => d.toISOString().split('T')[0];
      document.getElementById('ts_depart').value = fmt(today);
      document.getElementById('ts_return').value = fmt(ret);
    })();
  </script>

  <script>
    (function () {
      const card = document.getElementById('local-weather-card');
      const content = document.getElementById('local-weather-content');
      const loading = document.getElementById('local-weather-loading');

      if (!navigator.geolocation) return;
      card.hidden = false;

      const wmoEmoji = {0:'☀️',1:'🌤️',2:'⛅',3:'☁️',45:'🌫️',48:'🌫️',51:'🌦️',53:'🌦️',55:'🌦️',61:'🌧️',63:'🌧️',65:'🌧️',71:'🌨️',73:'🌨️',75:'❄️',77:'❄️',80:'🌦️',81:'🌦️',82:'🌧️',85:'🌨️',86:'🌨️',95:'⛈️',96:'⛈️',99:'⛈️'};
      const wmoLabel = {0:'Clear Sky',1:'Mainly Clear',2:'Partly Cloudy',3:'Overcast',45:'Foggy',48:'Icy Fog',51:'Light Drizzle',53:'Moderate Drizzle',55:'Heavy Drizzle',61:'Slight Rain',63:'Moderate Rain',65:'Heavy Rain',71:'Slight Snow',73:'Moderate Snow',75:'Heavy Snow',77:'Snow Grains',80:'Slight Showers',81:'Moderate Showers',82:'Heavy Showers',85:'Slight Snow Showers',86:'Heavy Snow Showers',95:'Thunderstorm',96:'Thunderstorm',99:'Heavy Thunderstorm'};

      navigator.geolocation.getCurrentPosition(async (pos) => {
        const { latitude: lat, longitude: lon } = pos.coords;
        try {
          const [weatherRes, geoRes] = await Promise.all([
            fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true&hourly=precipitation_probability&timezone=auto`),
            fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json`)
          ]);
          const weatherData = await weatherRes.json();
          const geoData = await geoRes.json();

          const cw = weatherData.current_weather;
          const temp = Math.round(cw.temperature);
          const wind = Math.round(cw.windspeed);
          const emoji = wmoEmoji[cw.weathercode] || '🌡️';
          const condition = wmoLabel[cw.weathercode] || 'Unknown';

          const hourlyTimes = weatherData.hourly.time;
          const hourlyPrecip = weatherData.hourly.precipitation_probability;
          let precipIndex = hourlyTimes.findIndex(t => t === cw.time);
          if (precipIndex === -1) precipIndex = 0;
          const precip = hourlyPrecip[precipIndex] ?? 0;

          const place = geoData.address?.city || geoData.address?.town || geoData.address?.village || geoData.address?.county || 'your location';
          const country = geoData.address?.country || '';

          content.innerHTML = `
            <div class="local-weather-meta">
              <span class="local-weather-pin">📍</span>
              <div class="local-weather-place-wrap">
                <span class="local-weather-place">${place}</span>
                ${country ? `<span class="local-weather-country">${country}</span>` : ''}
              </div>
              <span class="local-weather-badge"><%= locals.t ? t.weatherNearYou : 'Weather near you' %></span>
            </div>
            <div class="local-weather-stats">
              <div class="local-stat">
                <span class="local-stat-emoji">${emoji}</span>
                <span class="local-stat-value">${temp}°C</span>
                <span class="local-stat-label">${condition}</span>
              </div>
              <div class="local-stat-divider"></div>
              <div class="local-stat">
                <span class="local-stat-emoji">💨</span>
                <span class="local-stat-value">${wind} km/h</span>
                <span class="local-stat-label"><%= locals.t ? t.windLabel : 'Wind' %></span>
              </div>
              <div class="local-stat-divider"></div>
              <div class="local-stat">
                <span class="local-stat-emoji">🌂</span>
                <span class="local-stat-value">${precip}%</span>
                <span class="local-stat-label"><%= locals.t ? t.rainChance : 'Rain chance' %></span>
              </div>
            </div>
          `;
          loading.hidden = true;
          content.hidden = false;
        } catch (e) {
          card.hidden = true;
        }
      }, () => { card.hidden = true; });
    })();
  </script>

  <!-- Destinations Map -->
  <section class="map-section">
    <div class="map-section__header">
      <div class="container map-section__header-inner">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" fill="currentColor"/></svg>
        <h2><%= locals.t ? t.mapTitle : 'Holiday Destinations Map' %></h2>
      </div>
    </div>
    <div id="destinations-map"></div>
  </section>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WLs=" crossorigin=""></script>
  <script>
    (function () {
      const destinations = <%- JSON.stringify(displayCountries.map(c => ({
        name: c.displayName,
        flag: c.flag,
        lat: c.lat,
        lon: c.lon,
        slug: c.slug,
        localSlug: c.localSlug,
        temp: weatherMap[c.slug] ? weatherMap[c.slug].temperature : null,
        emoji: weatherMap[c.slug] ? weatherMap[c.slug].emoji : '🌡️',
      }))) %>;
      const prefix = '<%= weatherLinkPrefix %>';

      const map = L.map('destinations-map', { scrollWheelZoom: false }).setView([38, 18], 4);

      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
        maxZoom: 19
      }).addTo(map);

      destinations.forEach(d => {
        const tempLabel = d.temp !== null ? d.temp + '°C' : '—';
        const icon = L.divIcon({
          className: 'map-marker',
          html: `<div class="map-marker__inner"><span class="map-marker__flag">${d.flag}</span><span class="map-marker__temp">${tempLabel}</span></div>`,
          iconSize: [72, 36],
          iconAnchor: [36, 36],
          popupAnchor: [0, -38],
        });
        const marker = L.marker([d.lat, d.lon], { icon }).addTo(map);
        marker.bindPopup(`<div class="map-popup"><strong>${d.flag} ${d.name}</strong><br/>${d.emoji} ${tempLabel}<br/><a href="${prefix}${d.localSlug}" class="map-popup__link">View weather →</a></div>`);
      });
    })();
  </script>

