<!DOCTYPE html>
<html lang="<%= locals.lang || 'en' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= country.metaTitle %></title>
  <meta name="description" content="<%= country.metaDescription %>" />
  <% if (locals.alternates) { alternates.forEach(function(a) { %>
  <link rel="alternate" hreflang="<%= a.lang %>" href="<%= a.href %>" />
  <% }); } %>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" href="https://dmy0b9oeprz0f.cloudfront.net/holidayextras.co.uk/favicon/96/recent.jpg" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('partials/header', { user }) %>

  <!-- Hero -->
  <section class="weather-hero<% if (locals.heroImage) { %> weather-hero--photo<% } %>"<% if (locals.heroImage) { %> style="--hero-img: url('<%- heroImage %>')"<% } %>>
    <div class="container">
      <p class="hero-eyebrow"><%= t.liveWeather %></p>
      <h1><%= t.weatherIn %> <%= country.country %> <%= t.weatherInSuffix %></h1>
      <p class="hero-location"><%= t.showingConditionsFor %> <%= country.capital %></p>
    </div>
  </section>

  <!-- Language Switcher -->
  <% if (locals.alternates && alternates.length > 1) { %>
  <div class="lang-bar">
    <div class="container">
      <div class="lang-switcher">
        <% var langMeta = { en: { flag: '🇬🇧', label: 'EN' }, de: { flag: '🇩🇪', label: 'DE' }, fr: { flag: '🇫🇷', label: 'FR' }, es: { flag: '🇪🇸', label: 'ES' }, it: { flag: '🇮🇹', label: 'IT' } }; %>
        <span class="lang-switcher__label"><%= t.switchLanguage %></span>
        <% alternates.forEach(function(a) { var lm = langMeta[a.lang] || { flag: '', label: a.lang.toUpperCase() }; %>
          <a href="<%= a.href %>" class="lang-pill<%= (a.lang === (locals.lang || 'en')) ? ' lang-pill--active' : '' %>" hreflang="<%= a.lang %>"><%= lm.flag %> <%= lm.label %></a>
        <% }); %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- 7-Day Forecast Strip -->
  <% if (weather.forecast7day && weather.forecast7day.length) { %>
  <section class="forecast-strip-section">
    <div class="container">
      <div class="forecast-strip" id="forecast-strip" role="tablist" aria-label="7-day forecast">
        <% weather.forecast7day.forEach(function(day, i) { %>
        <button class="fsd-btn<%= i === 0 ? ' fsd-btn--active' : '' %>"
                role="tab"
                aria-selected="<%= i === 0 ? 'true' : 'false' %>"
                data-day="<%= i %>"
                onclick="selectDay(<%= i %>)">
          <span class="fsd-label"><%= day.dayLabel %></span>
          <span class="fsd-date"><%= day.dateLabel %></span>
          <span class="fsd-emoji"><%= day.emoji %></span>
          <span class="fsd-max"><%= day.tempMax %>°</span>
          <span class="fsd-min"><%= day.tempMin %>°</span>
        </button>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Weather Snapshot -->
  <section class="weather-snapshot-section">
    <div class="container">
      <div class="weather-card">
        <div class="weather-emoji" id="wc-emoji"><%= weather.emoji %></div>
        <div class="weather-condition" id="wc-condition"><%= weather.condition %></div>
        <div class="weather-stats">
          <div class="weather-stat">
            <span class="stat-value" id="wc-temp"><%= weather.temperature %>°C</span>
            <span class="stat-label" id="wc-temp-label"><%= t.temperature %></span>
          </div>
          <div class="weather-stat-divider"></div>
          <div class="weather-stat">
            <span class="stat-value" id="wc-rain"><%= weather.precipProbability %>%</span>
            <span class="stat-label"><%= t.rainChance %></span>
          </div>
          <div class="weather-stat-divider"></div>
          <div class="weather-stat">
            <span class="stat-value" id="wc-wind"><%= weather.windSpeed %> km/h</span>
            <span class="stat-label"><%= t.windSpeed %></span>
          </div>
        </div>
        <p class="weather-updated" id="wc-updated"><%= t.updatedLive %></p>
      </div>
    </div>
  </section>

  <!-- Forecast Section -->
  <section class="forecast-section">
    <div class="container">
      <div class="forecast-grid">

        <!-- Hourly panel (today only) -->
        <div class="forecast-hourly" id="hourly-panel">
          <div class="forecast-hourly__header">
            <h2><%= country.country %>: <span id="hourly-title">Next 24-Hour Weather</span></h2>
            <p class="forecast-date" id="hourly-date">Today — <%= weather.dateLabel %></p>
          </div>
          <div class="forecast-sunrow">
            <div class="forecast-sun">
              <span class="forecast-sun__icon">🌅</span>
              <span class="forecast-sun__label">SUNRISE</span>
              <span class="forecast-sun__time" id="fs-sunrise"><%= weather.sunrise %></span>
            </div>
            <div class="forecast-sun">
              <span class="forecast-sun__icon">🌇</span>
              <span class="forecast-sun__label">SUNSET</span>
              <span class="forecast-sun__time" id="fs-sunset"><%= weather.sunset %></span>
            </div>
          </div>
          <!-- Today's hourly slots -->
          <ul class="forecast-slots" id="hourly-slots">
            <% weather.nextHours.forEach(slot => { %>
            <li class="forecast-slot">
              <span class="forecast-slot__time"><%= slot.time %></span>
              <span class="forecast-slot__emoji"><%= slot.emoji %></span>
              <span class="forecast-slot__temp"><%= slot.temp %>°C</span>
            </li>
            <% }) %>
          </ul>
          <!-- Future day summary (hidden by default) -->
          <div class="future-day-summary" id="future-day-summary" style="display:none">
            <div class="future-day-temps">
              <span class="future-temp-high" id="fdp-max"></span>
              <span class="future-temp-slash">/</span>
              <span class="future-temp-low" id="fdp-min"></span>
            </div>
            <p class="future-day-note" id="fdp-note"></p>
          </div>
        </div>

        <!-- Stats panel -->
        <div class="forecast-stats">
          <div class="forecast-stat-row">
            <span class="forecast-stat-row__label">Temp feels like</span>
            <span class="forecast-stat-row__value" id="fs-feels"><%= weather.feelsLike %>°C</span>
          </div>
          <div class="forecast-stat-row">
            <span class="forecast-stat-row__label">Length of day</span>
            <span class="forecast-stat-row__value" id="fs-daylight"><%= weather.daylightH %>h <%= weather.daylightM %>m</span>
          </div>
          <div class="forecast-stat-row">
            <span class="forecast-stat-row__label">Pressure</span>
            <span class="forecast-stat-row__value" id="fs-pressure"><%= weather.pressure %> hpa</span>
          </div>
          <div class="forecast-stat-row">
            <span class="forecast-stat-row__label">Visibility</span>
            <span class="forecast-stat-row__value" id="fs-vis"><%= weather.visibility %> km</span>
          </div>
          <div class="forecast-stat-row">
            <span class="forecast-stat-row__label">Wind speed</span>
            <span class="forecast-stat-row__value" id="fs-wind"><%= weather.windSpeed %> km/h</span>
          </div>
          <div class="forecast-stat-row">
            <span class="forecast-stat-row__label">Rain chance</span>
            <span class="forecast-stat-row__value" id="fs-rain"><%= weather.precipProbability %>%</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SEO Content -->
  <section class="content-section">
    <div class="container content-inner">

      <div class="content-block">
        <h2><%= t.aboutWeatherIn %> <%= country.country %></h2>
        <p><%= country.seoIntro %></p>
      </div>

      <div class="content-grid">
        <div class="content-tile">
          <div class="tile-icon">🗓️</div>
          <h3><%= t.bestTimeToVisit %></h3>
          <p><%= country.bestTimeToVisit %></p>
        </div>
        <div class="content-tile">
          <div class="tile-icon">🎒</div>
          <h3><%= t.whatToPack %></h3>
          <p><%= country.packingTips %></p>
        </div>
      </div>

    </div>
  </section>

  <!-- Climate by Season -->
  <% if (country.seasons) { %>
  <section class="content-section season-section">
    <div class="container content-inner">
      <div class="content-block">
        <h2><%= t.climateBySeasonTitle %></h2>
      </div>
      <div class="season-grid">
        <div class="season-card">
          <div class="season-icon">🌸</div>
          <h3><%= t.spring %></h3>
          <div class="season-temp"><%= country.seasons.spring.temp %></div>
          <p><%= country.seasons.spring.desc %></p>
        </div>
        <div class="season-card">
          <div class="season-icon">☀️</div>
          <h3><%= t.summer %></h3>
          <div class="season-temp"><%= country.seasons.summer.temp %></div>
          <p><%= country.seasons.summer.desc %></p>
        </div>
        <div class="season-card">
          <div class="season-icon">🍂</div>
          <h3><%= t.autumn %></h3>
          <div class="season-temp"><%= country.seasons.autumn.temp %></div>
          <p><%= country.seasons.autumn.desc %></p>
        </div>
        <div class="season-card">
          <div class="season-icon">❄️</div>
          <h3><%= t.winter %></h3>
          <div class="season-temp"><%= country.seasons.winter.temp %></div>
          <p><%= country.seasons.winter.desc %></p>
        </div>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Local Weather Tips -->
  <% if (country.localTips && country.localTips.length) { %>
  <section class="content-section tips-section">
    <div class="container content-inner">
      <div class="content-block">
        <h2><%= t.localWeatherTipsTitle %></h2>
      </div>
      <ul class="weather-tips-list">
        <% country.localTips.forEach(function(tip) { %>
          <li class="weather-tip">
            <span class="weather-tip__icon">💡</span>
            <span><%= tip %></span>
          </li>
        <% }); %>
      </ul>
    </div>
  </section>
  <% } %>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2><%= t.readyToBook %> <%= country.country %><%= t.readyToBookSuffix %></h2>
      <p><%= t.lessHassle %></p>
      <a href="<%= country.ctaUrl %>" class="cta-button" target="_blank" rel="noopener">
        <%= t.findAirportHotels %> <%= country.country %><%= t.findAirportHotelsSuffix %>
      </a>
    </div>
  </section>

  <script>
    (function () {
      const todayData = {
        emoji: '<%- weather.emoji %>',
        condition: '<%- weather.condition.replace(/'/g, "\\'") %>',
        temperature: <%= weather.temperature %>,
        precipProbability: <%= weather.precipProbability %>,
        windSpeed: <%= weather.windSpeed %>,
        feelsLike: <%= weather.feelsLike %>,
        pressure: <%= weather.pressure %>,
        visibility: <%= weather.visibility %>,
        daylightH: <%= weather.daylightH %>,
        daylightM: <%= weather.daylightM %>,
        sunrise: '<%= weather.sunrise %>',
        sunset: '<%= weather.sunset %>',
        dateLabel: '<%= weather.dateLabel %>',
      };
      const forecast7day = <%- JSON.stringify(weather.forecast7day || []) %>;

      window.selectDay = function (i) {
        // Update tab active state
        document.querySelectorAll('.fsd-btn').forEach(function (btn, j) {
          btn.classList.toggle('fsd-btn--active', i === j);
          btn.setAttribute('aria-selected', i === j ? 'true' : 'false');
        });

        const day = forecast7day[i];
        const isToday = (i === 0);

        // Update weather card
        document.getElementById('wc-emoji').textContent = day.emoji;
        document.getElementById('wc-condition').textContent = day.condition;
        document.getElementById('wc-temp').textContent = isToday ? (todayData.temperature + '°C') : (day.tempMax + '°C');
        document.getElementById('wc-temp-label').textContent = isToday ? '<%= t.temperature %>' : 'High';
        document.getElementById('wc-rain').textContent = day.precipProbability + '%';
        document.getElementById('wc-wind').textContent = day.windSpeed + ' km/h';
        document.getElementById('wc-updated').style.display = isToday ? '' : 'none';

        // Update stats panel
        document.getElementById('fs-sunrise').textContent = day.sunrise;
        document.getElementById('fs-sunset').textContent = day.sunset;
        document.getElementById('fs-daylight').textContent = day.daylightH + 'h ' + day.daylightM + 'm';
        document.getElementById('fs-wind').textContent = day.windSpeed + ' km/h';
        document.getElementById('fs-rain').textContent = day.precipProbability + '%';
        document.getElementById('fs-feels').textContent = isToday ? (todayData.feelsLike + '°C') : (day.tempMax + '°C');
        document.getElementById('fs-pressure').textContent = isToday ? (todayData.pressure + ' hpa') : '—';
        document.getElementById('fs-vis').textContent = isToday ? (todayData.visibility + ' km') : '—';

        // Today: show hourly slots, hide future summary
        // Future: hide hourly slots, show future summary
        document.getElementById('hourly-slots').style.display = isToday ? '' : 'none';
        document.getElementById('future-day-summary').style.display = isToday ? 'none' : '';
        document.getElementById('hourly-date').textContent = isToday
          ? ('Today — ' + todayData.dateLabel)
          : (day.dayLabel + ' — ' + day.dateLabel);

        if (!isToday) {
          document.getElementById('fdp-max').textContent = day.tempMax + '°C';
          document.getElementById('fdp-min').textContent = day.tempMin + '°C';
          document.getElementById('fdp-note').textContent = day.condition + ' · ' + day.precipProbability + '% rain · ' + day.windSpeed + ' km/h wind';
        }
      };
    })();
  </script>

  <%- include('partials/footer') %>

</body>
</html>
