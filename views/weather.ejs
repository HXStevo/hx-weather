<!DOCTYPE html>
<html lang="<%= locals.lang || 'en' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= country.metaTitle %></title>
  <meta name="description" content="<%= country.metaDescription %>" />
  <% if (locals.alternates) { alternates.forEach(function(a) { %>
  <link rel="alternate" hreflang="<%= a.lang %>" href="<%= a.href %>" />
  <% }); } %>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('partials/header', { user }) %>

  <!-- Hero -->
  <section class="weather-hero<% if (locals.heroImage) { %> weather-hero--photo<% } %>"<% if (locals.heroImage) { %> style="--hero-img: url('<%- heroImage %>')"<% } %>>
    <div class="container">
      <p class="hero-eyebrow"><%= t.liveWeather %></p>
      <h1><%= t.weatherIn %> <%= country.country %> <%= t.weatherInSuffix %></h1>
      <p class="hero-location"><%= t.showingConditionsFor %> <%= country.capital %></p>
    </div>
  </section>

  <!-- Language Switcher -->
  <% if (locals.alternates && alternates.length > 1) { %>
  <div class="lang-bar">
    <div class="container">
      <div class="lang-switcher">
        <% var langMeta = { en: { flag: '🇬🇧', label: 'EN' }, de: { flag: '🇩🇪', label: 'DE' }, fr: { flag: '🇫🇷', label: 'FR' }, es: { flag: '🇪🇸', label: 'ES' }, it: { flag: '🇮🇹', label: 'IT' } }; %>
        <span class="lang-switcher__label"><%= t.switchLanguage %></span>
        <% alternates.forEach(function(a) { var lm = langMeta[a.lang] || { flag: '', label: a.lang.toUpperCase() }; %>
          <a href="<%= a.href %>" class="lang-pill<%= (a.lang === (locals.lang || 'en')) ? ' lang-pill--active' : '' %>" hreflang="<%= a.lang %>"><%= lm.flag %> <%= lm.label %></a>
        <% }); %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Weather Snapshot -->
  <section class="weather-snapshot-section">
    <div class="container">
      <div class="weather-card">
        <div class="weather-emoji"><%= weather.emoji %></div>
        <div class="weather-condition"><%= weather.condition %></div>
        <div class="weather-stats">
          <div class="weather-stat">
            <span class="stat-value"><%= weather.temperature %>°C</span>
            <span class="stat-label"><%= t.temperature %></span>
          </div>
          <div class="weather-stat-divider"></div>
          <div class="weather-stat">
            <span class="stat-value"><%= weather.precipProbability %>%</span>
            <span class="stat-label"><%= t.rainChance %></span>
          </div>
          <div class="weather-stat-divider"></div>
          <div class="weather-stat">
            <span class="stat-value"><%= weather.windSpeed %> km/h</span>
            <span class="stat-label"><%= t.windSpeed %></span>
          </div>
        </div>
        <p class="weather-updated"><%= t.updatedLive %></p>
      </div>
    </div>
  </section>

  <!-- SEO Content -->
  <section class="content-section">
    <div class="container content-inner">

      <div class="content-block">
        <h2><%= t.aboutWeatherIn %> <%= country.country %></h2>
        <p><%= country.seoIntro %></p>
      </div>

      <div class="content-grid">
        <div class="content-tile">
          <div class="tile-icon">🗓️</div>
          <h3><%= t.bestTimeToVisit %></h3>
          <p><%= country.bestTimeToVisit %></p>
        </div>
        <div class="content-tile">
          <div class="tile-icon">🎒</div>
          <h3><%= t.whatToPack %></h3>
          <p><%= country.packingTips %></p>
        </div>
      </div>

    </div>
  </section>

  <!-- Climate by Season -->
  <% if (country.seasons) { %>
  <section class="content-section season-section">
    <div class="container content-inner">
      <div class="content-block">
        <h2><%= t.climateBySeasonTitle %></h2>
      </div>
      <div class="season-grid">
        <div class="season-card">
          <div class="season-icon">🌸</div>
          <h3><%= t.spring %></h3>
          <div class="season-temp"><%= country.seasons.spring.temp %></div>
          <p><%= country.seasons.spring.desc %></p>
        </div>
        <div class="season-card">
          <div class="season-icon">☀️</div>
          <h3><%= t.summer %></h3>
          <div class="season-temp"><%= country.seasons.summer.temp %></div>
          <p><%= country.seasons.summer.desc %></p>
        </div>
        <div class="season-card">
          <div class="season-icon">🍂</div>
          <h3><%= t.autumn %></h3>
          <div class="season-temp"><%= country.seasons.autumn.temp %></div>
          <p><%= country.seasons.autumn.desc %></p>
        </div>
        <div class="season-card">
          <div class="season-icon">❄️</div>
          <h3><%= t.winter %></h3>
          <div class="season-temp"><%= country.seasons.winter.temp %></div>
          <p><%= country.seasons.winter.desc %></p>
        </div>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Local Weather Tips -->
  <% if (country.localTips && country.localTips.length) { %>
  <section class="content-section tips-section">
    <div class="container content-inner">
      <div class="content-block">
        <h2><%= t.localWeatherTipsTitle %></h2>
      </div>
      <ul class="weather-tips-list">
        <% country.localTips.forEach(function(tip) { %>
          <li class="weather-tip">
            <span class="weather-tip__icon">💡</span>
            <span><%= tip %></span>
          </li>
        <% }); %>
      </ul>
    </div>
  </section>
  <% } %>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2><%= t.readyToBook %> <%= country.country %><%= t.readyToBookSuffix %></h2>
      <p><%= t.lessHassle %></p>
      <a href="<%= country.ctaUrl %>" class="cta-button" target="_blank" rel="noopener">
        <%= t.findAirportHotels %> <%= country.country %><%= t.findAirportHotelsSuffix %>
      </a>
    </div>
  </section>

  <%- include('partials/footer') %>

</body>
</html>
